@* =============================================================
   Fichier : Library.Web/Shared/RedirectToLogin.razor
   Rôle    : Redirige vers /login si l'utilisateur n'est pas
             connecté. Utilise OnAfterRender pour que la
             navigation fonctionne correctement dans Blazor Server.
   ============================================================= *@

@inject AuthService AuthService
@inject NavigationManager Nav

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && !AuthService.IsLoggedIn)
            Nav.NavigateTo("/login", forceLoad: false);
    }
}
