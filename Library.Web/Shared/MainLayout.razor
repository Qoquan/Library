@* =============================================================
   Fichier : Library.Web/Shared/MainLayout.razor
   Rôle    : Layout principal. Affiche la nav avec le nom de
             l'utilisateur connecté et le bouton déconnexion.
   ============================================================= *@

@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager Nav

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">
            <i class="bi bi-book-half me-2"></i>Library
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            @if (AuthService.IsLoggedIn)
            {
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                            <i class="bi bi-house me-1"></i>Accueil
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/books">
                            <i class="bi bi-journal-text me-1"></i>Mes Livres
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/books/add">
                            <i class="bi bi-plus-circle me-1"></i>Ajouter
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/search-external">
                            <i class="bi bi-search me-1"></i>OpenLibrary
                        </NavLink>
                    </li>
                </ul>

                <ul class="navbar-nav ms-auto">
                    <li class="nav-item d-flex align-items-center me-3">
                        <span class="text-white-50 small">
                            <i class="bi bi-person-circle me-1"></i>
                            <strong class="text-white">@AuthService.CurrentUser!.Username</strong>
                        </span>
                    </li>
                    <li class="nav-item">
                        <button class="btn btn-outline-light btn-sm" @onclick="Logout">
                            <i class="bi bi-box-arrow-right me-1"></i>Déconnexion
                        </button>
                    </li>
                </ul>
            }
            else
            {
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/login">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Connexion
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/register">
                            <i class="bi bi-person-plus me-1"></i>Créer un compte
                        </a>
                    </li>
                </ul>
            }
        </div>
    </div>
</nav>

<main class="container my-4">
    @Body
</main>

<footer class="bg-dark text-white text-center py-3 mt-5">
    <small>
        <i class="bi bi-book me-1"></i>Library — Projet POO 5IOBJ-1
        @if (AuthService.IsLoggedIn)
        {
            <span> | Connecté en tant que <strong>@AuthService.CurrentUser!.Username</strong></span>
        }
    </small>
</footer>

@code {
    protected override void OnInitialized()
    {
        AuthService.OnAuthChanged += StateHasChanged;
    }

    private void Logout()
    {
        AuthService.Logout();
        Nav.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthService.OnAuthChanged -= StateHasChanged;
    }
}
