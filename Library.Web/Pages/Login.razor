@* =============================================================
   Fichier : Library.Web/Pages/Login.razor
   Rôle    : Page de connexion.
   Route   : /login
   ============================================================= *@

@page "/login"
@inject AuthService AuthService
@inject NavigationManager Nav

<PageTitle>Connexion — Library</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-5">

        <div class="text-center mb-4">
            <i class="bi bi-book-half text-primary" style="font-size: 3rem;"></i>
            <h2 class="mt-2 fw-bold">Library</h2>
            <p class="text-muted">Connectez-vous à votre bibliothèque</p>
        </div>

        <div class="card border-0 shadow">
            <div class="card-body p-4">
                <h4 class="card-title mb-4">
                    <i class="bi bi-box-arrow-in-right me-2 text-primary"></i>Connexion
                </h4>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label fw-semibold">Nom d'utilisateur</label>
                    <input class="form-control" placeholder="Entrez votre nom d'utilisateur"
                           @bind="username" @onkeyup="OnKeyUp" />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Mot de passe</label>
                    <input type="password" class="form-control" placeholder="Entrez votre mot de passe"
                           @bind="password" @onkeyup="OnKeyUp" />
                </div>

                <button class="btn btn-primary w-100" @onclick="DoLogin" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    else
                    {
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                    }
                    Se connecter
                </button>

                <hr class="my-3" />

                <p class="text-center text-muted mb-0">
                    Pas encore de compte ?
                    <a href="/register" class="text-primary fw-semibold">Créer un compte</a>
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string errorMessage = "";
    private bool isLoading = false;

    protected override void OnInitialized()
    {
        // Déjà connecté → redirige vers l'accueil
        if (AuthService.IsLoggedIn)
            Nav.NavigateTo("/");
    }

    private async Task OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await DoLogin();
    }

    private async Task DoLogin()
    {
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Veuillez remplir tous les champs.";
            return;
        }

        isLoading = true;
        errorMessage = "";

        var result = await AuthService.LoginAsync(username, password);

        isLoading = false;

        if (result.Success)
            Nav.NavigateTo("/");
        else
            errorMessage = result.Message;
    }
}
